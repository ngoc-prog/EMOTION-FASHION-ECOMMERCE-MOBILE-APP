<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/lume_background"
        android:paddingBottom="72dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Product image gallery with button overlays -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="360dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_product_images"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/lume_divider" />

                <!-- Back button (top-left) -->
                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="14dp"
                    android:src="@drawable/ic_back"
                    android:background="@drawable/bg_circle_white"
                    android:tint="@color/lume_text_primary"
                    android:padding="8dp"
                    android:elevation="4dp" />

                <!-- Wishlist button (top-right) -->
                <ImageButton
                    android:id="@+id/btn_detail_wishlist"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="14dp"
                    android:src="@drawable/ic_heart"
                    android:background="@drawable/bg_circle_white"
                    android:tint="@color/lume_text_secondary"
                    android:padding="8dp"
                    android:elevation="4dp"
                    android:contentDescription="@string/wishlist" />
            </FrameLayout>

            <!-- Dot indicators — on white background, always clearly visible -->
            <LinearLayout
                android:id="@+id/ll_dots"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@color/white" />

            <!-- Content card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="4dp"
                android:background="@color/white">

                <!-- Brand -->
                <TextView
                    android:id="@+id/tv_detail_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ÉLAN"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/lume_primary"
                    android:textStyle="bold" />

                <!-- Name -->
                <TextView
                    android:id="@+id/tv_detail_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_primary"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Rating row -->
                <LinearLayout
                    android:id="@+id/layout_detail_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:background="@drawable/bg_rating_pill"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star" />

                    <TextView
                        android:id="@+id/tv_detail_rating_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary_dark"
                        android:layout_marginStart="5dp" />

                    <TextView
                        android:id="@+id/tv_detail_rating_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/lume_text_secondary"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <!-- Price -->
                <TextView
                    android:id="@+id/tv_detail_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/lume_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp" />

                <!-- Hesitant promotion banner (animated in when HESITANT detected) -->
                <LinearLayout
                    android:id="@+id/layout_hesitant_promo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_promo_banner"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/promo_title"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/promo_subtitle"
                            android:textSize="12sp"
                            android:textColor="@color/lume_text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tv_promo_original_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/lume_text_secondary" />

                        <TextView
                            android:id="@+id/tv_promo_discounted_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_primary_dark"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Size selector -->
                <TextView
                    android:id="@+id/tv_size_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_size"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/lume_text_secondary"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <LinearLayout
                    android:id="@+id/ll_size_chips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/lume_divider"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="18dp" />

                <!-- Description label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/product_description"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="@color/lume_text_secondary"
                    android:textStyle="bold" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/lume_text_primary"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.6" />

                <!-- Gemini recommendation card -->
                <com.example.emotioncommerce.ui.RecommendationCardView
                    android:id="@+id/recommendation_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp" />

                <!-- Reviews section -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/lume_divider"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp" />

                <!-- Reviews header: label + avg score -->
                <LinearLayout
                    android:id="@+id/layout_reviews_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/customer_reviews"
                            android:textSize="11sp"
                            android:letterSpacing="0.1"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_secondary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_star" />

                            <TextView
                                android:id="@+id/tv_reviews_avg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C2E"
                                android:layout_marginStart="6dp" />

                            <TextView
                                android:id="@+id/tv_reviews_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_secondary"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Reviews list (non-scrollable, inside NestedScrollView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginTop="4dp" />

                <!-- Debug toggle (admin only — hidden by default, shown in Java for admin) -->
                <Button
                    android:id="@+id/btn_debug_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/debug"
                    android:textSize="11sp"
                    android:visibility="gone"
                    style="?attr/materialButtonOutlinedStyle" />

                <!-- Debug text -->
                <TextView
                    android:id="@+id/tv_debug_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:padding="10dp"
                    android:background="#1A000000"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/lume_text_primary"
                    android:lineSpacingMultiplier="1.4" />

                <!-- Camera preview (debug) -->
                <androidx.camera.view.PreviewView
                    android:id="@+id/camera_preview"
                    android:layout_width="100dp"
                    android:layout_height="130dp"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky bottom action bar -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp"
        android:paddingHorizontal="16dp">

        <!-- Price row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Label + price stacked vertically -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_label"
                    android:textSize="10sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:textColor="@color/lume_text_secondary" />

                <TextView
                    android:id="@+id/tv_sticky_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.0"
                    android:textColor="@color/lume_primary_dark" />
            </LinearLayout>

            <!-- Emotion indicator lives here in the bar -->
            <com.example.emotioncommerce.ui.EmotionIndicatorView
                android:id="@+id/emotion_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_add_to_cart"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/add_to_cart"
                android:backgroundTint="#F5F0EB"
                android:textColor="@color/lume_primary_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="24dp" />

            <Button
                android:id="@+id/btn_buy_now"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/buy_now"
                android:backgroundTint="@color/lume_primary_dark"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Calibration overlay (covers everything including sticky bar) -->
    <LinearLayout
        android:id="@+id/calibration_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="#CC000000">

        <TextView
            android:id="@+id/tv_calibration_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="#FFFFFF"
            android:textSize="64sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/calibrating"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/look_at_camera"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFF" />
    </LinearLayout>

</FrameLayout>
