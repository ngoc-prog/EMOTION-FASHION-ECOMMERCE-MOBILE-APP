<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tv_timeline_time"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:textColor="@color/lume_text_secondary" />

    <View
        android:id="@+id/view_timeline_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginEnd="10dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_timeline_product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/lume_text_primary"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tv_timeline_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/lume_text_secondary"
            android:layout_marginTop="1dp" />
    </LinearLayout>

</LinearLayout>
