<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="3dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/profile_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:textColor="@color/lume_text_primary" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profile_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile hero card with gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/hero_banner"
                android:padding="28dp"
                android:gravity="center">

                <!-- Avatar with ring -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp">

                    <!-- Ring -->
                    <View
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/bg_avatar_ring" />

                    <!-- Inner circle -->
                    <FrameLayout
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_gravity="center">
                        <View
                            android:layout_width="76dp"
                            android:layout_height="76dp"
                            android:background="@drawable/bg_avatar_circle" />
                        <TextView
                            android:id="@+id/tv_avatar_letter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="K"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </FrameLayout>
                </FrameLayout>

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/guest"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_profile_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/login_for_full"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF" />

                <Button
                    android:id="@+id/btn_profile_login"
                    android:layout_width="160dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/login_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="@color/lume_primary_dark"
                    app:cornerRadius="20dp" />
            </LinearLayout>

            <!-- Stats card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:paddingVertical="16dp"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_cart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_cart"
                        android:textSize="11sp"
                        android:textColor="@color/lume_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="@color/lume_divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_wishlist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_wishlist"
                        android:textSize="11sp"
                        android:textColor="@color/lume_text_secondary" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="40dp"
                    android:background="@color/lume_divider" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tv_stat_viewed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stat_viewed"
                        android:textSize="11sp"
                        android:textColor="@color/lume_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Admin tools card (only visible to admin) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/btn_admin_analytics"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_analytics"
                            android:tint="@color/lume_primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/analytics_dashboard"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_admin"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_primary_dark"
                            android:background="@drawable/bg_tag_gold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/lume_divider"
                        android:layout_marginStart="52dp" />

                    <LinearLayout
                        android:id="@+id/btn_admin_management"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_person"
                            android:tint="@color/lume_primary_dark" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/admin_management"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_admin"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_primary_dark"
                            android:background="@drawable/bg_tag_gold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/lume_divider"
                        android:layout_marginStart="52dp" />

                    <LinearLayout
                        android:id="@+id/btn_research_mode"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_analytics"
                            android:tint="#4CAF50" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/research_mode"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_research"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"
                            android:background="@drawable/bg_tag_green"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Mua sắm -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_shopping"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/lume_text_secondary"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_profile_row" android:id="@+id/row_orders" />
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/lume_divider" android:layout_marginStart="56dp" />
                    <include layout="@layout/item_profile_row" android:id="@+id/row_wishlist" />
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/lume_divider" android:layout_marginStart="56dp" />
                    <include layout="@layout/item_profile_row" android:id="@+id/row_address" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Khác -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_other"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:textColor="@color/lume_text_secondary"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <include layout="@layout/item_profile_row" android:id="@+id/row_about" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="@string/logout"
                android:textColor="#C62828"
                android:backgroundTint="#FFF0F0"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="25dp" />

            <View android:layout_width="match_parent" android:layout_height="16dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

        <ImageButton
            android:id="@+id/btn_scroll_top"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_arrow_up"
            android:background="@drawable/bg_scroll_top"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:elevation="6dp"
            android:visibility="gone"
            android:contentDescription="@string/scroll_to_top" />
    </FrameLayout>
</LinearLayout>
