<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="3dp"
        android:paddingLeft="4dp"
        android:paddingRight="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/lume_primary_dark"
            android:padding="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Giỏ hàng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />
    </RelativeLayout>

    <!-- Empty state -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp">

        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp">

            <View
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_recommendation_card" />

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:tint="@color/lume_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Giỏ hàng của bạn trống"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Khám phá bộ sưu tập thời trang &amp; phụ kiện\nvà thêm sản phẩm yêu thích nhé!"
            android:textSize="14sp"
            android:textColor="@color/lume_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

        <Button
            android:id="@+id/btn_continue_shopping"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginTop="28dp"
            android:text="Tiếp tục mua sắm"
            android:backgroundTint="@color/lume_primary_dark"
            android:textColor="@android:color/white"
            android:paddingLeft="28dp"
            android:paddingRight="28dp" />
    </LinearLayout>

</LinearLayout>
