<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Selection checkbox -->
        <CheckBox
            android:id="@+id/cb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:buttonTint="@color/checkbox_tint"
            android:background="@drawable/ripple_brand" />

        <!-- Product image -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_cart_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="@color/lume_divider"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_cart_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/lume_primary"
                android:layout_marginBottom="3dp" />

            <TextView
                android:id="@+id/tv_cart_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/lume_text_primary"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2" />

            <TextView
                android:id="@+id/tv_cart_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/lume_text_secondary"
                android:layout_marginTop="3dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_cart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/lume_primary_dark"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

            <!-- Qty stepper -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_qty_stepper"
                android:paddingHorizontal="4dp">

                <ImageButton
                    android:id="@+id/btn_decrement"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_minus"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/lume_primary_dark"
                    android:padding="7dp"
                    android:contentDescription="@string/qty_decrease" />

                <TextView
                    android:id="@+id/tv_quantity"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_primary" />

                <ImageButton
                    android:id="@+id/btn_increment"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_plus"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/lume_primary_dark"
                    android:padding="7dp"
                    android:contentDescription="@string/qty_increase" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_remove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/lume_text_secondary"
            android:padding="6dp"
            android:contentDescription="@string/remove" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
