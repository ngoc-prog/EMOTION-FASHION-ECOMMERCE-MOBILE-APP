<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- Header + search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="3dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/app_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:textColor="@color/lume_primary_dark" />

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true">

                <ImageButton
                    android:id="@+id/btn_cart"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_cart"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@color/lume_primary_dark"
                    android:padding="10dp" />

                <TextView
                    android:id="@+id/tv_cart_badge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_badge_red"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </RelativeLayout>

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="10dp">

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_search_input"
                android:paddingLeft="42dp"
                android:paddingRight="14dp"
                android:hint="@string/search_hint"
                android:textSize="13sp"
                android:textColorHint="@color/lume_text_secondary"
                android:textColor="@color/lume_text_primary"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/btn_clear_search"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/lume_text_secondary"
                android:padding="8dp"
                android:visibility="gone"
                android:contentDescription="@string/clear_search" />

            <!-- Filter button with active badge -->
            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="4dp">

                <ImageButton
                    android:id="@+id/btn_filter"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_filter"
                    android:background="@drawable/bg_filter_btn"
                    android:tint="@color/lume_primary_dark"
                    android:padding="10dp" />

                <TextView
                    android:id="@+id/tv_filter_badge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_badge_red"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- Category filter chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="2dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:id="@+id/filter_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Section title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="3dp"
            android:layout_height="18dp"
            android:background="@color/lume_primary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_product_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/featured_products"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />

        <!-- Emotion boost hint badge -->
        <TextView
            android:id="@+id/tv_boost_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textSize="11sp"
            android:textColor="@color/lume_primary_dark"
            android:textStyle="bold"
            android:background="@drawable/bg_tag_gold"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Loading + Grid -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="10dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />

        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="@color/lume_primary"
            android:visibility="visible" />

        <LinearLayout
            android:id="@+id/layout_no_results"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_products_found"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/lume_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/try_other_search"
                android:textSize="13sp"
                android:textColor="@color/lume_text_secondary" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_scroll_top"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:src="@drawable/ic_arrow_up"
            android:background="@drawable/bg_scroll_top"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:elevation="6dp"
            android:visibility="gone"
            android:contentDescription="@string/scroll_to_top" />
    </FrameLayout>

</LinearLayout>
