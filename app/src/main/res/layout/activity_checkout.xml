<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back_checkout"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:padding="14dp"
            android:src="@drawable/ic_back"
            android:tint="@color/lume_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/checkout_title"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:textColor="@color/lume_text_primary" />
    </RelativeLayout>

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp"
        android:paddingTop="2dp">

        <!-- Step 1: Cart (completed) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✓"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_success_circle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/step_cart"
                android:textSize="10sp"
                android:textColor="@color/lume_primary" />
        </LinearLayout>

        <!-- Connector line -->
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@color/lume_primary" />

        <!-- Step 2: Payment (active) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_step_active" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/step_payment"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/lume_primary_dark" />
        </LinearLayout>

        <!-- Connector line (inactive) -->
        <View
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@color/lume_divider" />

        <!-- Step 3: Done (inactive) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="3"
                android:textSize="13sp"
                android:textColor="@color/lume_text_secondary"
                android:background="@drawable/bg_step_inactive" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/step_done"
                android:textSize="10sp"
                android:textColor="@color/lume_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ── Order summary ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section header with accent bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/lume_primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/tv_order_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/order_section"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/lume_divider" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_order_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/lume_divider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/subtotal"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_secondary" />
                        <TextView
                            android:id="@+id/tv_subtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/shipping_fee"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_secondary" />
                        <TextView
                            android:id="@+id/tv_shipping_fee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textColor="#2E7D32" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/free_ship_note"
                        android:textSize="11sp"
                        android:textColor="@color/lume_text_secondary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Address picker (Shopee-style) ────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_address_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/lume_primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/shipping_address"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />

                        <TextView
                            android:id="@+id/btn_change_address"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/change_address"
                            android:textSize="13sp"
                            android:textColor="@color/lume_primary_dark"
                            android:textStyle="bold"
                            android:padding="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>

                    <!-- Address display (when an address is picked) -->
                    <LinearLayout
                        android:id="@+id/layout_picked_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginTop="2dp"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/ic_location"
                            android:tint="@color/lume_primary_dark" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_picked_name_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_primary" />

                            <TextView
                                android:id="@+id/tv_picked_address"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Prompt when no address saved -->
                    <TextView
                        android:id="@+id/tv_no_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/no_saved_address"
                        android:textSize="13sp"
                        android:textColor="@color/lume_text_secondary"
                        android:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Shipping info ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section header with accent bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/lume_primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shipping_info"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_name_required"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/lume_text_secondary" />

                    <EditText
                        android:id="@+id/et_checkout_name"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:inputType="textPersonName"
                        android:textSize="14sp"
                        android:textColor="@color/lume_text_primary"
                        android:textColorHint="@color/lume_text_secondary"
                        android:hint="@string/hint_name"
                        android:imeOptions="actionNext"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_phone_required"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/lume_text_secondary" />

                    <EditText
                        android:id="@+id/et_checkout_phone"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:textSize="14sp"
                        android:textColor="@color/lume_text_primary"
                        android:textColorHint="@color/lume_text_secondary"
                        android:hint="@string/hint_phone"
                        android:imeOptions="actionNext"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_address_required"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/lume_text_secondary" />

                    <EditText
                        android:id="@+id/et_checkout_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:inputType="textPostalAddress|textMultiLine"
                        android:textSize="14sp"
                        android:textColor="@color/lume_text_primary"
                        android:textColorHint="@color/lume_text_secondary"
                        android:hint="@string/hint_address"
                        android:imeOptions="actionNext"
                        android:minLines="2"
                        android:gravity="top|start" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_city_required"
                        android:textSize="12sp"
                        android:letterSpacing="0.05"
                        android:textColor="@color/lume_text_secondary" />

                    <RelativeLayout
                        android:id="@+id/et_checkout_city"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tv_city_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@+id/iv_city_arrow"
                            android:paddingStart="14dp"
                            android:text="@string/choose_city"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_secondary"
                            android:singleLine="true"
                            android:ellipsize="end" />

                        <ImageView
                            android:id="@+id/iv_city_arrow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp"
                            android:src="@drawable/ic_dropdown_arrow"
                            android:tint="@color/lume_text_secondary" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Payment method ─────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section header with accent bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="3dp"
                            android:layout_height="16dp"
                            android:background="@color/lume_primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_method"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/lume_text_primary" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/rg_payment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_cod"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginBottom="8dp"
                            android:paddingStart="14dp"
                            android:text="@string/pay_cod"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_primary"
                            android:checked="true"
                            android:background="@drawable/bg_payment_option"
                            android:buttonTint="@color/lume_primary_dark" />

                        <RadioButton
                            android:id="@+id/rb_bank"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginBottom="8dp"
                            android:paddingStart="14dp"
                            android:text="@string/pay_bank"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_primary"
                            android:background="@drawable/bg_payment_option"
                            android:buttonTint="@color/lume_primary_dark" />

                        <RadioButton
                            android:id="@+id/rb_card"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:paddingStart="14dp"
                            android:text="@string/pay_card"
                            android:textSize="14sp"
                            android:textColor="@color/lume_text_primary"
                            android:background="@drawable/bg_payment_option"
                            android:buttonTint="@color/lume_primary_dark" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky bottom bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/total_payment"
                android:textSize="13sp"
                android:textColor="@color/lume_text_secondary" />

            <TextView
                android:id="@+id/tv_checkout_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/lume_primary_dark" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_place_order"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/place_order"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/lume_primary_dark"
            app:cornerRadius="26dp" />
    </LinearLayout>

</LinearLayout>
