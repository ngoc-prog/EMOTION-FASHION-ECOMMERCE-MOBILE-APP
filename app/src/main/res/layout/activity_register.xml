<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header band — matches Login style -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/hero_banner">

        <ImageButton
            android:id="@+id/btn_register_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#CCFFFFFF"
            android:padding="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/brand_tagline"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:textColor="#CCFFFFFF" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/lume_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/register_subtitle"
                android:textSize="13sp"
                android:textColor="@color/lume_text_secondary" />

            <!-- Full name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/full_name"
                android:textSize="12sp"
                android:letterSpacing="0.03"
                android:textColor="@color/lume_text_secondary" />

            <EditText
                android:id="@+id/et_register_name"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:hint="@string/hint_name"
                android:textSize="14sp"
                android:textColorHint="@color/lume_text_secondary"
                android:textColor="@color/lume_text_primary"
                android:inputType="textPersonName|textCapWords"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/email"
                android:textSize="12sp"
                android:letterSpacing="0.03"
                android:textColor="@color/lume_text_secondary" />

            <EditText
                android:id="@+id/et_register_email"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:hint="@string/hint_email"
                android:textSize="14sp"
                android:textColorHint="@color/lume_text_secondary"
                android:textColor="@color/lume_text_primary"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/password"
                android:textSize="12sp"
                android:letterSpacing="0.03"
                android:textColor="@color/lume_text_secondary" />

            <EditText
                android:id="@+id/et_register_password"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:hint="@string/hint_min6"
                android:textSize="14sp"
                android:textColorHint="@color/lume_text_secondary"
                android:textColor="@color/lume_text_primary"
                android:inputType="textPassword"
                android:imeOptions="actionNext"
                android:singleLine="true" />

            <!-- Confirm password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/confirm_password"
                android:textSize="12sp"
                android:letterSpacing="0.03"
                android:textColor="@color/lume_text_secondary" />

            <EditText
                android:id="@+id/et_register_confirm"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_input_field"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:hint="@string/hint_reenter_password"
                android:textSize="14sp"
                android:textColorHint="@color/lume_text_secondary"
                android:textColor="@color/lume_text_primary"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <TextView
                android:id="@+id/tv_register_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="#D32F2F"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/register_title"
                android:backgroundTint="@color/lume_primary_dark"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/have_account"
                    android:textSize="13sp"
                    android:textColor="@color/lume_text_secondary" />

                <TextView
                    android:id="@+id/tv_go_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/lume_primary_dark" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
