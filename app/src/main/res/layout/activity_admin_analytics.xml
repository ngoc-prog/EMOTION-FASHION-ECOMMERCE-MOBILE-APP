<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- ── Header (gradient) ───────────────────────────────────────────── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_admin_header"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:padding="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analytics"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tv_session_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phiên hiện tại"
                android:textSize="10sp"
                android:textColor="#BBFFFFFF"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ── TabLayout ────────────────────────────────────────────────────── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:elevation="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/lume_primary_dark"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="@color/lume_primary_dark"
        app:tabTextColor="@color/lume_text_secondary"
        android:visibility="gone" />

    <!-- ── Empty state ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_no_data"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_analytics"
            android:tint="@color/lume_divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Chưa có dữ liệu"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hãy xem một vài sản phẩm để hệ thống thu thập dữ liệu cảm xúc"
            android:textSize="13sp"
            android:textColor="@color/lume_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>

    <!-- ── Tab content panels ───────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/tab_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <!-- ── Panel 0: Tổng quan ──────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_overview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THỐNG KÊ PHIÊN"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_secondary"
                    android:layout_marginBottom="10dp" />

                <!-- Row 1: SP xem + Thời gian -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="10dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:background="#C09A6A" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tv_stat_products"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="34sp"
                                    android:textStyle="bold"
                                    android:textColor="#C09A6A" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sản phẩm xem"
                                    android:textSize="11sp"
                                    android:textColor="@color/lume_text_secondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="10dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:background="#7BA7BC" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tv_stat_time"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0s"
                                    android:textSize="34sp"
                                    android:textStyle="bold"
                                    android:textColor="#7BA7BC" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thời gian xem"
                                    android:textSize="11sp"
                                    android:textColor="@color/lume_text_secondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: Giỏ hàng + Yêu thích -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="10dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:background="#5BAD6F" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tv_stat_carts"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="34sp"
                                    android:textStyle="bold"
                                    android:textColor="#5BAD6F" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thêm giỏ hàng"
                                    android:textSize="11sp"
                                    android:textColor="@color/lume_text_secondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp"
                        app:cardMaxElevation="10dp"
                        app:cardBackgroundColor="@color/white">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="5dp"
                                android:background="#E08080" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="14dp"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/tv_stat_wishlists"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="34sp"
                                    android:textStyle="bold"
                                    android:textColor="#E08080" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Yêu thích"
                                    android:textSize="11sp"
                                    android:textColor="@color/lume_text_secondary"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHÂN BỐ CẢM XÚC"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_secondary"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="10dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="Hứng thú"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_interested"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#4CAF50"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_interested"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="Phân vân"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_hesitant"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#FF9800"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_hesitant"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="Thờ ơ"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_indifferent"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="@color/lume_text_secondary"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_indifferent"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 1: Sản phẩm ───────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XẾP HẠNG THEO HỨNG THÚ"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_secondary"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_product_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 2: Timeline ───────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_timeline"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DÒNG THỜI GIAN"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_secondary"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_timeline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingVertical="4dp" />
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 3: AI Insights ────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_ai"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐỀ XUẤT TỪ AI"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/lume_text_secondary"
                    android:layout_marginBottom="10dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gemini phân tích dữ liệu cảm xúc và đề xuất cải thiện cho cửa hàng"
                            android:textSize="13sp"
                            android:textColor="@color/lume_text_secondary"
                            android:lineSpacingMultiplier="1.4" />

                        <Button
                            android:id="@+id/btn_generate_insights"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="Phân tích với Gemini"
                            android:backgroundTint="@color/lume_primary_dark"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            app:cornerRadius="24dp" />

                        <ProgressBar
                            android:id="@+id/pb_insights_loading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/lume_primary"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_insights_result"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:textSize="13sp"
                            android:textColor="@color/lume_text_primary"
                            android:lineSpacingMultiplier="1.7"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
