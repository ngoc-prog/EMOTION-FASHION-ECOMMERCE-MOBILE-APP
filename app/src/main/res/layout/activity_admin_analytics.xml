<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- ── Header (hero gradient, consistent with app) ─────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hero_banner"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="18dp">

            <!-- Top row: back + badge -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="4dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="@android:color/white"
                    android:padding="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:text="@string/badge_admin"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:textColor="#FFE3C08D"
                    android:background="#26FFFFFF"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />
            </RelativeLayout>

            <!-- Title block -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="@string/analytics_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tv_session_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="3dp"
                android:text="@string/analytics_subtitle"
                android:textSize="12sp"
                android:textColor="#BBFFFFFF" />

            <!-- Quick stat pills -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tv_pill_products"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 sản phẩm"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="#33FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_pill_emotion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="#33FFFFFF"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- ── TabLayout ────────────────────────────────────────────────────── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:elevation="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/lume_primary"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabSelectedTextColor="@color/lume_primary_dark"
        app:tabTextColor="@color/lume_text_secondary"
        app:tabTextAppearance="@style/AdminTabText"
        android:visibility="gone" />

    <!-- ── Empty state ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layout_no_data"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:background="@drawable/bg_circle_cream">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_analytics"
                android:tint="@color/lume_primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/no_data"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/no_data_sub"
            android:textSize="13sp"
            android:textColor="@color/lume_text_secondary"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />
    </LinearLayout>

    <!-- ── Tab content panels ───────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/tab_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <!-- ── Panel 0: Tổng quan ──────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_overview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section: stats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/session_stats"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <!-- 2×2 stat cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Card: Products viewed -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FFF5E6">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="👁"
                                android:textSize="18sp"
                                android:background="@drawable/bg_stat_icon_gold"
                                android:padding="4dp" />

                            <TextView
                                android:id="@+id/tv_stat_products"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="0"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#8B6840"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/stat_products_viewed"
                                android:textSize="11sp"
                                android:textColor="#C09A6A" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card: View time -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#E8F4FD">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="⏱"
                                android:textSize="18sp"
                                android:background="@drawable/bg_stat_icon_blue"
                                android:padding="4dp" />

                            <TextView
                                android:id="@+id/tv_stat_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="0s"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#2E7BAE"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/stat_view_time"
                                android:textSize="11sp"
                                android:textColor="#5B9DC9" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <!-- Card: Add to cart -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#EDFBF0">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="🛒"
                                android:textSize="18sp"
                                android:background="@drawable/bg_stat_icon_green"
                                android:padding="4dp" />

                            <TextView
                                android:id="@+id/tv_stat_carts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="0"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D50"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/stat_add_cart"
                                android:textSize="11sp"
                                android:textColor="#5BAD80" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Card: Wishlist -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FEF0F0">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="♥"
                                android:textSize="18sp"
                                android:textColor="#E53935"
                                android:background="@drawable/bg_stat_icon_red"
                                android:padding="4dp" />

                            <TextView
                                android:id="@+id/tv_stat_wishlists"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="0"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#C0392B"
                                android:includeFontPadding="false" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/wishlist"
                                android:textSize="11sp"
                                android:textColor="#E08080" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Section: emotion distribution -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emotion_distribution"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/emotion_interested"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_interested"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#4CAF50"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_interested"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#4CAF50"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/emotion_hesitant"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_hesitant"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="#FF9800"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_hesitant"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <TextView
                                android:layout_width="72dp"
                                android:layout_height="wrap_content"
                                android:text="@string/emotion_indifferent"
                                android:textSize="13sp"
                                android:textColor="@color/lume_text_primary" />
                            <ProgressBar
                                android:id="@+id/pb_dist_indifferent"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="10dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="0"
                                android:progressTint="@color/lume_text_secondary"
                                android:progressBackgroundTint="@color/lume_divider" />
                            <TextView
                                android:id="@+id/tv_pct_indifferent"
                                android:layout_width="38dp"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:gravity="end"
                                android:layout_marginStart="8dp"
                                android:text="0%" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 1: Sản phẩm ───────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_products"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ranking_by_interest"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_product_stats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 2: Timeline ───────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_timeline"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/timeline_section"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/white">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_timeline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingVertical="6dp" />
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ── Panel 3: AI Insights ────────────────────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/panel_ai"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_suggestions"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/gemini_desc"
                            android:textSize="13sp"
                            android:textColor="@color/lume_text_secondary"
                            android:lineSpacingMultiplier="1.4" />

                        <Button
                            android:id="@+id/btn_generate_insights"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="14dp"
                            android:text="@string/analyze_with_gemini"
                            android:backgroundTint="@color/lume_primary_dark"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            app:cornerRadius="24dp" />

                        <ProgressBar
                            android:id="@+id/pb_insights_loading"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="12dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/lume_primary"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_insights_result"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:textSize="13sp"
                            android:textColor="@color/lume_text_primary"
                            android:lineSpacingMultiplier="1.7"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Reset analytics card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#FFE0D0"
                    app:cardBackgroundColor="#FFF8F5">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/analytics_reset_title"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#C0392B" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/analytics_reset_desc"
                            android:textSize="12sp"
                            android:textColor="@color/lume_text_secondary"
                            android:lineSpacingMultiplier="1.4" />

                        <Button
                            android:id="@+id/btn_reset_analytics"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/analytics_reset_btn"
                            android:backgroundTint="#C0392B"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:cornerRadius="20dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="match_parent" android:layout_height="16dp" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
