<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/lume_background">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:elevation="3dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Giỏ hàng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/lume_text_primary" />
    </RelativeLayout>

    <!-- Content area: takes all remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Cart items list — shown when cart is non-empty -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_cart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:visibility="gone" />

        <!-- Empty state — shown when cart is empty -->
        <LinearLayout
            android:id="@+id/layout_empty_cart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="visible">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <View
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_recommendation_card" />

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cart"
                    android:tint="@color/lume_primary" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Giỏ hàng của bạn trống"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/lume_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Khám phá bộ sưu tập thời trang &amp; phụ kiện\nvà thêm sản phẩm yêu thích nhé!"
                android:textSize="14sp"
                android:textColor="@color/lume_text_secondary"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5" />

            <Button
                android:id="@+id/btn_continue_shopping"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="28dp"
                android:text="Tiếp tục mua sắm"
                android:backgroundTint="@color/lume_primary_dark"
                android:textColor="@android:color/white"
                android:paddingLeft="28dp"
                android:paddingRight="28dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Checkout section — shown when cart is non-empty -->
    <LinearLayout
        android:id="@+id/layout_checkout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lume_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng cộng"
                android:textSize="14sp"
                android:textColor="@color/lume_text_secondary" />

            <TextView
                android:id="@+id/tv_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/lume_primary_dark" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_checkout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="Đặt hàng"
            android:backgroundTint="@color/lume_primary_dark"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
