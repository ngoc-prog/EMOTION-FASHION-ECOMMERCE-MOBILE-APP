<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lume_background">

    <!-- ── Main content ──────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/white"
            android:elevation="3dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/lume_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/research_mode_title"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/lume_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:text="@string/badge_research"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:background="@drawable/bg_tag_green"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />
        </RelativeLayout>

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- ── Card 1: Current Prediction ──────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/current_prediction"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_predicted_emotion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/calibrating_dash"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_secondary"
                        android:gravity="center"
                        android:padding="14dp"
                        android:background="@drawable/bg_recommendation_card"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tv_features_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BRR: —  |  MC: —  |  MAR: —  |  BFD: —"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/lume_text_secondary"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_latency_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Frame: —ms  |  Avg: —ms  |  ~—fps"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:textColor="@color/lume_text_secondary"
                        android:gravity="center" />
                </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Card 2: Ground Truth Buttons ────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ground_truth"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/gt_instructions"
                        android:textSize="12sp"
                        android:textColor="@color/lume_text_secondary"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_gt_interested"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/emotion_interested"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#4CAF50"
                            android:enabled="false"
                            app:cornerRadius="10dp" />

                        <Button
                            android:id="@+id/btn_gt_hesitant"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:text="@string/emotion_hesitant"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#FF9800"
                            android:enabled="false"
                            app:cornerRadius="10dp" />

                        <Button
                            android:id="@+id/btn_gt_indifferent"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/emotion_indifferent"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#9E9E9E"
                            android:enabled="false"
                            app:cornerRadius="10dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_last_record"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/no_samples_yet"
                        android:textSize="12sp"
                        android:textColor="@color/lume_text_secondary"
                        android:gravity="center" />
                </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Card 3: Confusion Matrix ─────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/confusion_matrix"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_accuracy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/accuracy_empty"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary_dark"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/bg_recommendation_card"
                        android:layout_marginBottom="14dp" />

                    <!-- Matrix table: header + 3 data rows -->
                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="0,1,2,3">

                        <!-- Header row -->
                        <TableRow>
                            <TextView
                                android:text=""
                                android:padding="4dp" />
                            <TextView
                                android:text="@string/pred_interested"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#388E3C"
                                android:gravity="center"
                                android:padding="4dp" />
                            <TextView
                                android:text="@string/pred_hesitant"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#E65100"
                                android:gravity="center"
                                android:padding="4dp" />
                            <TextView
                                android:text="@string/pred_indifferent"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#6D4C41"
                                android:gravity="center"
                                android:padding="4dp" />
                        </TableRow>

                        <!-- Row 0: GT = Hứng thú -->
                        <TableRow>
                            <TextView
                                android:text="@string/gt_interested"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#388E3C"
                                android:gravity="center"
                                android:padding="4dp" />
                            <TextView
                                android:id="@+id/tv_cm_00"
                                android:text="0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#E8F5E9" />
                            <TextView
                                android:id="@+id/tv_cm_01"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                            <TextView
                                android:id="@+id/tv_cm_02"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                        </TableRow>

                        <!-- Row 1: GT = Phân vân -->
                        <TableRow>
                            <TextView
                                android:text="@string/gt_hesitant"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#E65100"
                                android:gravity="center"
                                android:padding="4dp" />
                            <TextView
                                android:id="@+id/tv_cm_10"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                            <TextView
                                android:id="@+id/tv_cm_11"
                                android:text="0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FFF3E0" />
                            <TextView
                                android:id="@+id/tv_cm_12"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                        </TableRow>

                        <!-- Row 2: GT = Thờ ơ -->
                        <TableRow>
                            <TextView
                                android:text="@string/gt_indifferent"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#6D4C41"
                                android:gravity="center"
                                android:padding="4dp" />
                            <TextView
                                android:id="@+id/tv_cm_20"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                            <TextView
                                android:id="@+id/tv_cm_21"
                                android:text="0"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#FAFAFA" />
                            <TextView
                                android:id="@+id/tv_cm_22"
                                android:text="0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="8dp"
                                android:background="#EFEBE9" />
                        </TableRow>
                    </TableLayout>
                </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Card 4: Per-Class Metrics ────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="@color/lume_primary"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/eval_metrics"
                        android:textSize="12sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:textColor="@color/lume_text_primary" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="0,1,2,3">

                        <!-- Header -->
                        <TableRow>
                            <TextView
                                android:text="@string/label_col"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:padding="6dp" />
                            <TextView
                                android:text="Precision"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:text="Recall"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:text="F1-Score"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/lume_text_secondary"
                                android:gravity="center"
                                android:padding="6dp" />
                        </TableRow>

                        <!-- Hứng thú -->
                        <TableRow>
                            <TextView
                                android:text="@string/emotion_interested"
                                android:textSize="12sp"
                                android:textColor="#388E3C"
                                android:textStyle="bold"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_prec_int"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_rec_int"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_f1_int"
                                android:text="—"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="6dp" />
                        </TableRow>

                        <!-- Phân vân -->
                        <TableRow>
                            <TextView
                                android:text="@string/emotion_hesitant"
                                android:textSize="12sp"
                                android:textColor="#E65100"
                                android:textStyle="bold"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_prec_hes"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_rec_hes"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_f1_hes"
                                android:text="—"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="6dp" />
                        </TableRow>

                        <!-- Thờ ơ -->
                        <TableRow>
                            <TextView
                                android:text="@string/emotion_indifferent"
                                android:textSize="12sp"
                                android:textColor="#6D4C41"
                                android:textStyle="bold"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_prec_ind"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_rec_ind"
                                android:text="—"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:padding="6dp" />
                            <TextView
                                android:id="@+id/tv_f1_ind"
                                android:text="—"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:padding="6dp" />
                        </TableRow>
                    </TableLayout>
                </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Action buttons ─────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btn_export_csv"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="@string/export_csv"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/lume_primary_dark"
                        app:cornerRadius="24dp" />

                    <Button
                        android:id="@+id/btn_clear_data"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="@string/clear_data"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/lume_primary"
                        android:backgroundTint="#FFF8F0"
                        style="?attr/materialButtonOutlinedStyle"
                        app:cornerRadius="24dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_toggle_camera"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="@string/show_camera"
                    android:textSize="12sp"
                    android:textColor="@color/lume_text_secondary"
                    android:backgroundTint="@color/lume_divider"
                    android:layout_marginBottom="32dp"
                    app:cornerRadius="20dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- ── Floating camera preview (top-right corner) ──────────────────── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="110dp"
        android:layout_height="82dp"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:elevation="4dp"
        android:visibility="invisible" />

    <!-- ── Calibration overlay (full-screen, shown on first open) ──────── -->
    <LinearLayout
        android:id="@+id/calibration_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#DD000000"
        android:padding="32dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/calibration_baseline"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_calib_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:textColor="#C09A6A"
            android:textSize="64sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/look_neutral"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_skip_calibration"
            android:layout_width="160dp"
            android:layout_height="40dp"
            android:text="@string/skip_calibration"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:backgroundTint="#44FFFFFF" />
    </LinearLayout>

</FrameLayout>
