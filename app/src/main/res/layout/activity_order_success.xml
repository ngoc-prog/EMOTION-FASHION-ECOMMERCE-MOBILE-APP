<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp">

    <!-- Check circle icon -->
    <View
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_success_circle" />

    <!-- Checkmark drawn via TextView overlay -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-72dp"
        android:text="✓"
        android:textSize="44sp"
        android:textStyle="bold"
        android:textColor="@android:color/white" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Đặt hàng thành công!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/lume_text_primary" />

    <TextView
        android:id="@+id/tv_order_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:textColor="@color/lume_primary_dark"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_order_total_success"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="15sp"
        android:textColor="@color/lume_text_primary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Cảm ơn bạn đã tin tưởng ÉLAN.\nChúng tôi sẽ liên hệ xác nhận đơn hàng trong vòng 30 phút."
        android:textSize="13sp"
        android:textColor="@color/lume_text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

    <Button
        android:id="@+id/btn_continue_shopping"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="36dp"
        android:text="Tiếp tục mua sắm"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/lume_primary_dark" />

</LinearLayout>
